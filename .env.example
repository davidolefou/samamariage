# ============================================================
# SAMAMARIAGE - Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS COMMITTER .env.local
# ============================================================

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
DATABASE_URL=postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres

# --- IA ---
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...
OPENAI_API_KEY=sk-...         # optionnel
ELEVENLABS_API_KEY=...         # pour faire-part audio

# --- CACHE (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# --- PAIEMENTS ---
PAYDUNYA_MASTER_KEY=...
PAYDUNYA_PRIVATE_KEY=...
PAYDUNYA_TOKEN=...
PAYDUNYA_MODE=test             # test | live
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- COMMUNICATIONS ---
RESEND_API_KEY=re_...
TWILIO_ACCOUNT_SID=AC...       # SMS + WhatsApp OTP
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890
WHATSAPP_BOT_NUMBER=+221...    # numéro Wave Business WhatsApp

# --- ANALYTICS ---
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# --- MONITORING ---
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=...
SENTRY_ORG=samamariage
SENTRY_PROJECT=samamariage-web

# --- STOCKAGE ---
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=samamariage-uploads

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
