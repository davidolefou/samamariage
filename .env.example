# =============================================================================
# izi kit — environment reference
# =============================================================================
# Copy this file to `.env.local` (or `.env`) at the repo root, then fill in
# the values you need. Keys are grouped by:
#
#   1. REQUIRED at boot (the app refuses to start without these)
#   2. RECOMMENDED at boot (warn-only; the app boots, but breaks at first use)
#   3. OPTIONAL providers (Cloudinary / Resend / Bictorys / Google OAuth / Sentry / Upstash)
#       — entirely env-gated, the app boots and `/api/auth` works without them
#   4. TUNABLES (auth lockout, rate limits, withdrawal policy, upload policy …)
#
# Source of truth for the validation schema:
#   frontend/src/lib/server/env.ts (boot-time zod schema, throws on misconfig)
# =============================================================================


# =============================================================================
# 1. REQUIRED at boot
# =============================================================================

# Postgres connection — Neon's "-pooler" host routes through PgBouncer in
# transaction mode. `connection_limit=1` is REQUIRED on serverless: each
# Vercel function instance opens its own pool, and per-instance multi-conn
# pools exhaust Neon's ceiling under moderate concurrency.
#
# This kit is cloud-only: there is NO local Postgres. Create a free Neon
# project at https://neon.tech, copy the `-pooler` connection string here
# and the non-pooled string into DIRECT_URL below.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?pgbouncer=true&connection_limit=1&pool_timeout=15&sslmode=require"

# JWT signing secret — minimum 32 chars (validator rejects shorter values
# at boot). Generate with: `openssl rand -base64 48`
# Strings starting with "change-me", "secret", "test"… are rejected.
JWT_SECRET=""


# =============================================================================
# 2. RECOMMENDED at boot
# =============================================================================

# Direct (non-pooled) Postgres URL — REQUIRED for `prisma migrate deploy`.
# The pooler exhausts on long-lived migrations and breaks prepared statements.
# Without DIRECT_URL set, migrations time out or fail mid-run.
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# Vercel Cron auth shared secret. Required by /api/cron/* routes.
# Generate with: `openssl rand -base64 32`
# Single shared secret across all cron handlers.
CRON_SECRET=""

# AES-256-GCM encryption key for sensitive blob fields (OAuth refresh tokens,
# integration secrets). Required once you store encrypted data — Phase 1 auth
# works without it. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=""


# =============================================================================
# 3. APP origin / cookies
# =============================================================================

# Public origin URL — used for email link generation, OAuth callback base,
# and CORS construction. Set this per environment.
APP_URL="http://localhost:3000"

# Comma-separated additional CORS origins (when serving from multiple domains).
# Leave empty to accept only same-origin (default in a monolith).
ALLOWED_ORIGINS=""

# Cookie name prefix. All auth cookies are namespaced "${COOKIE_PREFIX}-token",
# "${COOKIE_PREFIX}-refresh", "${COOKIE_PREFIX}-csrf". Change per app so a dev
# sharing localhost across two starters doesn't clobber sessions.
COOKIE_PREFIX="app"

# Cookie domain for production (e.g. ".example.com" so cookies are shared
# across www.example.com and api.example.com). Leave empty for localhost dev.
# COOKIE_DOMAIN=""

# Mirrors COOKIE_PREFIX for the browser bundle (must be NEXT_PUBLIC_*).
NEXT_PUBLIC_COOKIE_PREFIX="app"

# Node environment. The logger redacts PII when this is "production" or any
# unknown value (fail-safe). Leave unset / "development" locally.
# NODE_ENV=development


# =============================================================================
# 4. OPTIONAL — Upstash Redis (rate limit, leader-lease, lockout, refresh-lock)
# =============================================================================
# Without these, the rate limiter falls back to an in-memory store
# (logged as `log.warn` at boot). DO NOT run in production without Upstash —
# in-memory state is per-instance and resets on every cold start.

UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# =============================================================================
# 5. OPTIONAL — Email (Resend)
# =============================================================================
# Without these, the email queue (EmailJob rows) accumulates but is never
# drained — the cron `/api/cron/email-queue-drain` logs a warn and skips.
# Once the API key arrives, queued rows flush on the next cron tick.

RESEND_API_KEY=""

# Verified sender — must match a domain or address verified in your Resend
# project. Format accepts `"Name <addr@domain.com>"` or plain `addr@domain.com`.
EMAIL_FROM=""


# =============================================================================
# 6. OPTIONAL — Cloudinary (media storage)
# =============================================================================
# Required for `POST /api/upload` — without these the route returns
# 503 STORAGE_NOT_CONFIGURED. Leave empty if your project doesn't need
# uploads; the rest of the kit boots fine.
#
# Sign up free at https://cloudinary.com — copy the three values straight
# from the dashboard ("Cloud name", "API Key", "API Secret"). No bucket
# policies, no S3 keys, no endpoint URL — that's the whole setup.
#
# ⚠️ SECURITY — Cloudinary `secure_url` is publicly accessible. Anyone with
# the URL can fetch the file (no auth, no expiry). This is fine for avatars,
# product images, public posts. For private files (KYC docs, invoices, IDs)
# you MUST add Cloudinary signed delivery URLs or implement your own
# owner-gated proxy route — the v1 kit ships neither.

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional: named upload preset (server-side config in the Cloudinary
# dashboard — Settings → Upload). Use it to apply default folders, eager
# transformations, or tag conventions without changing route code. Leave
# empty for the default signed-upload behaviour.
CLOUDINARY_UPLOAD_PRESET=""


# =============================================================================
# 7. OPTIONAL — Google OAuth
# =============================================================================
# Get these at https://console.cloud.google.com/apis/credentials
# (OAuth 2.0 Client ID, type "Web application"). The authorized redirect URI
# in Google Console must match GOOGLE_REDIRECT_URI exactly.
# Without these, /api/auth/oauth/google/* routes return 404.

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/oauth/google/callback"


# =============================================================================
# 8. OPTIONAL — Payments (Bictorys, Senegalese mobile money)
# =============================================================================
# Without these, /api/orders, /api/withdrawals, /api/webhooks/bictorys are
# inert. Auth + uploads still work.

# Charges API key (calls outbound to https://api.bictorys.com).
BICTORYS_API_KEY=""

# Payouts API key — DISTINCT from BICTORYS_API_KEY (do not confuse them).
# Required only when using payouts (withdrawal disbursement).
BICTORYS_PRIVATE_KEY=""

# Override base URL (sandbox/staging swaps).
BICTORYS_API_URL="https://api.bictorys.com"

# Webhook HMAC secret — paired with the receiver in /api/webhooks/bictorys.
BICTORYS_WEBHOOK_SECRET=""

# Merchant secret code — payouts only.
BICTORYS_MERCHANT_SECRET_CODE=""

# Webhook replay window in milliseconds (default: 60000 = 60s). Webhook events
# whose timestamp is older than this fail the freshness check (anti-replay).
BICTORYS_WEBHOOK_REPLAY_WINDOW_MS="60000"

# Comma-separated retry delays in ms for the charge call (defaults to a
# bounded exponential schedule). Override for chaos testing or sandbox tuning.
# Example: BICTORYS_RETRY_DELAYS_MS_OVERRIDE="100,500,2000"
BICTORYS_RETRY_DELAYS_MS_OVERRIDE=""

# Marketplace commission rate in basis points (600 = 6%, 800 = 8%).
# Leave empty to skip commission computation.
COMMISSION_RATE_BP=""


# =============================================================================
# 9. OPTIONAL — Sentry (error reporting + tracing)
# =============================================================================
# Without SENTRY_DSN / NEXT_PUBLIC_SENTRY_DSN, the Sentry SDKs become silent
# no-ops (no events sent, no perf overhead).

# Server-side DSN:
SENTRY_DSN=""
# SENTRY_ENVIRONMENT="production"            # defaults to NODE_ENV
# SENTRY_RELEASE="myapp@1.2.3"               # set by CI for source-map matching
# SENTRY_TRACES_SAMPLE_RATE="0.1"            # 0.0–1.0 — default 0 (off)

# Frontend (browser) DSN — separate Sentry project recommended so client
# events don't pollute server-side dashboards.
NEXT_PUBLIC_SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_ENVIRONMENT="production"
# NEXT_PUBLIC_SENTRY_RELEASE="myapp@1.2.3"
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
# NEXT_PUBLIC_SENTRY_REPLAYS_SAMPLE_RATE="0"  # session replay opt-in (costly)

# Source-map upload (CI only). Without these the build still succeeds but
# stack traces won't be symbolicated in Sentry.
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""


# =============================================================================
# 10. TUNABLES — Auth (Phase 1)
# =============================================================================
# All optional. Defaults below are production-safe (per CONTEXT.md decisions
# D-06, D-07, D-08, D-10, D-13). Override only with cause.

# Minimum password length (NIST 800-63B aligned).
AUTH_PASSWORD_MIN_LENGTH=10

# Verification code TTL in minutes. Codes are 8-char Crockford alphanumeric,
# single-use (consumed via VerificationCode.usedAt).
AUTH_VERIFICATION_TTL_MIN=15

# Failed-login lockout (AUTH-10). After AUTH_LOCKOUT_THRESHOLD failures within
# AUTH_LOCKOUT_DURATION_MIN minutes, the account is locked out for the same
# duration. Backed by Redis sliding-window counter (memory fallback in dev).
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_DURATION_MIN=15

# Per-email rate limits (AUTH-10). Keyed on lower-cased email, falls back to
# per-IP when the email is missing (parse failure / malformed body).
AUTH_LOGIN_RATE_LIMIT_MAX=10              # 10 / 15 min per email
AUTH_SIGNUP_RATE_LIMIT_MAX=5              # 5 / 1 hour per email
AUTH_FORGOT_RATE_LIMIT_MAX=3              # 3 / 1 hour per email
AUTH_RESET_RATE_LIMIT_MAX=5               # 5 / 15 min per email
AUTH_RESEND_VERIFY_RATE_LIMIT_MAX=3       # 3 / 1 hour per email (reserved for future endpoint)
AUTH_VERIFY_RATE_LIMIT_MAX=5              # 5 / 15 min per email

# HIBP haveibeenpwned password check. Opt-in (default OFF).
# When enabled, signup / reset-password / change-password reject passwords
# found in known breaches via k-anonymity (first 5 chars of SHA-1 sent to
# api.pwnedpasswords.com — full password and full hash never leave the server).
# Fail-open on network error (logs warn).
PASSWORD_HIBP_CHECK=

# Email rate-limiter behaviour when Upstash is unreachable.
# Default OFF (fail-open) — the limiter logs warn and lets the request through
# so a Redis blip doesn't take auth offline. In prod with real abuse pressure
# you probably want fail-closed (return 429). Set to "1" to enable.
AUTH_RATE_LIMIT_FAIL_CLOSED=

# /api/auth/forgot-password wall-clock floor (ms). Pads each response so the
# user-exists vs. no-user paths are timing-indistinguishable, defending
# against email-enumeration timing attacks. 350ms = production-safe default.
# Set to "0" in tests to avoid 350ms per case.
AUTH_FORGOT_TARGET_LATENCY_MS=350


# =============================================================================
# 11. TUNABLES — Upload policy (Phase 4, applied by POST /api/upload)
# =============================================================================

# Comma-separated MIME whitelist. Magic bytes verified by sniff.ts; extending
# this list to a MIME without a sniffer logs a boot warning and trusts the
# client (XSS risk on text-ish formats — your call).
UPLOAD_ALLOWED_MIME="image/jpeg,image/png,image/webp"

# Max single-file size in bytes (10 MB default). Vercel Route Handlers can
# stream past the platform 4.5 MB body limit via req.formData(), but bigger
# files = bigger Vercel + Cloudinary bills.
UPLOAD_MAX_BYTES="10485760"


# =============================================================================
# 12. TUNABLES — Withdrawal policy (Phase 4, production-safe defaults)
# =============================================================================
# ⚠️  These are FINANCIAL policy. Read each comment before editing in prod.

# Min withdrawal amount in smallest currency unit (XOF default → 1000 ≈ 1.50 USD).
WITHDRAWAL_MIN_AMOUNT="1000"

# Cap per single withdrawal request (smallest unit). Empty = unlimited.
WITHDRAWAL_MAX_AMOUNT=""

# Cap on sum of withdrawals per 24h (smallest unit). Empty = unlimited.
WITHDRAWAL_DAILY_LIMIT=""

# Min hours between withdrawal requests per user. 0 = no cooldown.
WITHDRAWAL_COOLDOWN_HOURS="0"

# 1 = require PIN in body on POST /api/withdrawals. 0 = no PIN required
# (NOT recommended for real-money projects).
WITHDRAWAL_REQUIRE_PIN="1"

# WITHDRAWAL_BALANCE_CHECK
# Default: 1 (balance check enabled — withdrawals must not exceed balance)
# ⚠️  FINANCIAL-SAFETY WARNING — DO NOT CASUALLY DISABLE  ⚠️
# Set to 0 ONLY if you have an alternative ledger that gates withdrawals
# upstream of this route (e.g., your own balance-tracking microservice).
# Disabling on a real-money project = users can withdraw money they don't
# have. This is a compliance regression. Document the alternative ledger
# in your fork's CLAUDE.md or README before flipping this.
WITHDRAWAL_BALANCE_CHECK="1"


# =============================================================================
# 13. TUNABLES — Webhook log retention + order expiration (Phase 5)
# =============================================================================

# /api/cron/webhook-log-purge (daily) deletes WebhookLog rows older than this.
# Compliance teams sometimes want 1y or 7y retention; flip this knob without
# re-deploying. Default 90 days.
WEBHOOK_LOG_RETENTION_DAYS="90"

# Fork-customizable knob for the order-creation route to compute
# Order.expiresAt = createdAt + N minutes. The /api/cron/order-expiration
# (every 5 min) reads Order.expiresAt directly and is INDEPENDENT of this env
# — but forks adjusting checkout windows tweak this single value rather than
# the route code. Default 30 min.
ORDER_EXPIRATION_MINUTES="30"


# =============================================================================
# 14. DEV-ONLY — Smoke tests and local bypasses
# =============================================================================
# These only matter when running scripts/* locally; they are NEVER read by the
# server in production. Setting them in a prod env has no effect.

# Override target host for `pnpm smoke:auth` (defaults to http://localhost:3000).
# Use against a Vercel preview deploy or a colleague's tunnel:
# SMOKE_BASE_URL="https://my-preview.vercel.app"
SMOKE_BASE_URL=""

# 1 = bypass HMAC verification in /api/webhooks/* during local smoke tests.
# NEVER set this in production — it disables the anti-replay + integrity guard.
# Used by the optional webhook-side smoke harness (not enabled in v1).
SMOKE_BYPASS_WEBHOOK_VERIFY=""


# =============================================================================
# 15. OPTIONAL — Banani MCP (design import workflow, see WORKFLOW.md)
# =============================================================================
# Banani is an OPTIONAL design tool. Connect it via MCP if you have designs
# already drawn — the `banani-design-implementation` skill reads your selected
# screens directly and reproduces them pixel-perfect. If you don't have a
# Banani project, ignore this section entirely and describe your screens in
# natural language to Claude instead. The setup-kit skill walks through the
# MCP connection in Phase 5 (oui / non / plus tard branching).
#
# Note: Banani gives you a free MCP connection block (no paid API key) — you
# paste the block straight into .mcp.json. This BANANI_API_KEY env var is only
# needed if the connection block Banani gives you references a token env var;
# leave empty otherwise.
BANANI_API_KEY=""
