{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000 --turbopack",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:integration": "echo 'Phase 1: deferred to Phase 4 — see CONTEXT.md D-26' && exit 0",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:make-superadmin": "tsx --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/make-superadmin.ts",
    "seed:dev": "tsx --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/seed-dev.ts",
    "smoke:auth": "tsx --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/smoke-auth.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.52.0",
    "@upstash/redis": "^1.34.3",
    "@vercel/otel": "^2.1.2",
    "arctic": "^3.7.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "heic-convert": "^2.1.0",
    "jose": "^6.2.3",
    "next": "^16.2.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/heic-convert": "^2.1.0",
    "@types/node": "^20.17.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.20",
    "eslint-config-next": "^16.2.6",
    "fast-glob": "^3.3.3",
    "postcss": "^8.5.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4",
    "vitest-mock-extended": "^3.1.1"
  }
}
